<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_activity.xml — Page 1 (index 1) of ChildDashboardActivity ViewPager2
    ─────────────────────────────────────────────────────────────────────
    Contains: "Your Activity" title + rvChildAppUsage RecyclerView
    Swiped to from fragment_dashboard.xml (Page 1)
-->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/kyzen_green_bg_light"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:paddingBottom="88dp"
        android:clipToPadding="false">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your Activity"
            style="@style/KyzenTextTitle"
            android:layout_marginBottom="12dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvChildAppUsage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:overScrollMode="never"
            android:clipToPadding="false" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
