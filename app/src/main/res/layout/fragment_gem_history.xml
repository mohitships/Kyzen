<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_gem_history.xml — Page 3 (index 2) of ChildDashboardActivity ViewPager2.
    Shows gem transaction history — credits and debits in chronological order.
    Empty state shown when no transactions exist yet.
-->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/kyzen_green_bg_light"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:paddingBottom="88dp"
        android:clipToPadding="false">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gem History"
            style="@style/KyzenTextTitle"
            android:layout_marginBottom="4dp" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Every gem you earned and spent"
            android:textSize="12sp"
            android:textColor="@color/kyzen_grey_medium"
            android:layout_marginBottom="16dp" />

        <!-- Transaction list card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardTransactions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/kyzen_grey_divider"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvGemHistory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never"
                android:clipToPadding="false" />

        </com.google.android.material.card.MaterialCardView>

        <!-- Empty state — shown when no transactions exist yet -->
        <LinearLayout
            android:id="@+id/layoutEmptyState"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="60dp"
            android:paddingBottom="60dp"
            android:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💎"
                android:textSize="48sp"
                android:textColor="#FF000000"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your gem story starts here"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/kyzen_green_dark"
                android:textAlignment="center"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Focus on something productive to earn your first gem."
                android:textSize="13sp"
                android:textColor="@color/kyzen_grey_medium"
                android:textAlignment="center"
                android:lineSpacingExtra="3dp" />

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
