<?xml version="1.0" encoding="utf-8"?>
<!--
    dialog_detox_cancel.xml — Cancel confirmation dialog for DetoxBreakActivity
    ─────────────────────────────────────────────────────────────────────────────
    Shown when child taps "Emergency Cancel" or back button during a detox break.
    SDT framing: honest, non-shaming, gives child a genuine choice.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_card"
    android:paddingStart="28dp"
    android:paddingEnd="28dp"
    android:paddingTop="32dp"
    android:paddingBottom="24dp"
    android:layout_margin="24dp">

    <!-- Icon -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🌿"
        android:textSize="40sp"
        android:gravity="center"
        android:layout_gravity="center_horizontal"
        android:includeFontPadding="false"
        android:layout_marginBottom="16dp" />

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="End break early?"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/kyzen_navy"
        android:gravity="center"
        android:layout_marginBottom="10dp" />

    <!-- Elapsed time pill — dynamic, injected by Kotlin -->
    <TextView
        android:id="@+id/txtCancelElapsed"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0 mins elapsed — no gems awarded"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="@color/kyzen_amber_dark"
        android:gravity="center"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:background="@drawable/bg_cancel_pill"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp" />

    <!-- Body message — dynamic, injected by Kotlin -->
    <TextView
        android:id="@+id/txtCancelBody"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Is there something you genuinely need to do right now, or is it just hard to stay? Both are okay to admit."
        android:textSize="14sp"
        android:textColor="@color/kyzen_grey_dark"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:layout_marginBottom="28dp" />

    <!-- Stay with it — primary action (green, encouraging) -->
    <Button
        android:id="@+id/btnCancelStay"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Stay with it 💪"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textAllCaps="false"
        android:textColor="@color/kyzen_white"
        android:backgroundTint="@color/kyzen_green_dark"
        android:stateListAnimator="@null"
        android:letterSpacing="0.02"
        android:layout_marginBottom="10dp" />

    <!-- End break — ghost style (secondary, less prominent) -->
    <Button
        android:id="@+id/btnCancelConfirm"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="End the break"
        android:textSize="13sp"
        android:textAllCaps="false"
        android:textColor="@color/kyzen_grey_medium"
        android:backgroundTint="@android:color/transparent"
        android:stateListAnimator="@null"
        android:letterSpacing="0.02" />

</LinearLayout>
