<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_parent_usage.xml — Page 1 (index 1) of ParentDashboardActivity ViewPager2
    ──────────────────────────────────────────────────────────────────────────────────
    Contains: "Today's App Usage" title + rvParentAppUsage RecyclerView.
    Swiped to from fragment_parent_settings.xml (Page 0).

    Background: kyzen_yellow_bg — matches activity and settings fragment.
    paddingBottom="88dp" — clears the dot indicator bar at the bottom.

    ID inventory:
      rvParentAppUsage — bound in ParentUsageFragment.onViewCreated()
-->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/kyzen_yellow_bg"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:paddingBottom="88dp"
        android:clipToPadding="false">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Today's App Usage"
            style="@style/KyzenTextTitle"
            android:layout_marginBottom="12dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvParentAppUsage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:overScrollMode="never"
            android:clipToPadding="false" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
