<?xml version="1.0" encoding="utf-8"?>
<!-- Achievement pill background — used in the Hero Wallet card of the child dashboard.
     Full-width pill with light green fill and green border. Fixed shape, never resizes. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <corners android:radius="100dp" />
    <solid android:color="@color/kyzen_green_bg" />
    <stroke
        android:width="1dp"
        android:color="@color/kyzen_green_light" />
</shape>
