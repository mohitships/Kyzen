<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Permissions required by the Flow player module for video playback -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <application>
        <!--
            FlowPlayerActivity — the single entry point into the embedded Flow player.
            Launched via explicit Intent from Kyzen's UsageMonitorService intercept overlay
            when the child selects "Watch for Learning".

            No launcher intent-filter — this Activity is NOT a home-screen entry point.
            It is launched exclusively from within Kyzen via:
                Intent(context, FlowPlayerActivity::class.java)

            exported=false — internal Activity, not callable by other apps.
        -->
        <activity
            android:name="io.github.aedev.flow.ui.player.FlowPlayerActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:taskAffinity=".flowPlayer"
            android:configChanges="orientation|screenSize|screenLayout|smallestScreenSize|keyboard|keyboardHidden|uiMode"
            android:launchMode="singleTask"
            android:resizeableActivity="true"
            android:supportsPictureInPicture="true"
            android:screenOrientation="portrait"
            android:theme="@android:style/Theme.Black.NoTitleBar.Fullscreen"
            android:windowSoftInputMode="adjustResize" />
    </application>

</manifest>
